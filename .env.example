# ============================================================
# Mise — Hospitality Inventory Management
# Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Database (Supabase)
# Pooled connection for app queries (port 6543)
DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Direct connection for migrations (port 5432)
DIRECT_URL=postgres://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Auth (NextAuth.js)
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...

# Email (Resend)
RESEND_API_KEY=re_...
ALERT_EMAIL_FROM=noreply@mise.app

# Error tracking (Sentry) — optional in development
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=mise

# Internal admin dashboard — comma-separated emails that can access /admin
ADMIN_EMAILS=
