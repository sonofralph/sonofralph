# ============================================================
# Stockwise — Hospitality Inventory Management System
# Environment Variables
# ============================================================

# ------------------------------------------------------------
# Database (Required)
# ------------------------------------------------------------
# For self-hosted (docker-compose):
DATABASE_URL="postgresql://stockwise:changeme@localhost:5432/stockwise"

# For Supabase (SaaS mode):
# DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ------------------------------------------------------------
# NextAuth.js (Required)
# ------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"

# ------------------------------------------------------------
# Supabase (Optional - for SaaS deployment)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ------------------------------------------------------------
# Docker (for docker-compose)
# ------------------------------------------------------------
POSTGRES_PASSWORD="changeme"

# ------------------------------------------------------------
# Optional: Feature Flags
# ------------------------------------------------------------
# ENABLE_REAL_TIME=true
# ENABLE_EMAIL_ALERTS=false
