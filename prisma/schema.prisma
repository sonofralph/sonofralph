generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  plan           String   @default("FREE")
  deploymentMode String   @default("SAAS")
  businessType   String   @default("RESTAURANT")
  logoUrl        String?
  brandColor     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  goLiveAt       DateTime?

  users          User[]
  locations      Location[]
  categories     Category[]
  items          Item[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  alerts         Alert[]
  recipes        Recipe[]
  auditLogs      AuditLog[]
  requisitions   Requisition[]
  shiftHandovers ShiftHandover[]
  comments       Comment[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  jobTitle       String?
  passwordHash   String?
  role           String   @default("STAFF")
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization              Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements                 StockMovement[]
  auditLogs                 AuditLog[]
  notificationPreferences   NotificationPreference[]
  requisitionsRequested     Requisition[]             @relation("RequisitionRequester")
  requisitionsReviewed      Requisition[]             @relation("RequisitionReviewer")
  shiftHandovers            ShiftHandover[]
  comments                  Comment[]
}

model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String
  alertType String
  email     Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alertType])
}

model Location {
  id             String   @id @default(cuid())
  name           String
  type           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryRecords InventoryRecord[]
  movements        StockMovement[]
  alerts           Alert[]
  requisitions     Requisition[]
  shiftHandovers   ShiftHandover[]
}

model Category {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        Item[]
}

model Item {
  id             String   @id @default(cuid())
  name           String
  sku            String
  description    String?
  unit           String
  unitCost       Float    @default(0)
  expiryDays     Int?
  trackingType   String   @default("CONSUMABLE")
  organizationId String
  categoryId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category           Category            @relation(fields: [categoryId], references: [id])
  inventoryRecords   InventoryRecord[]
  movements          StockMovement[]
  purchaseLines      PurchaseOrderLine[]
  alerts             Alert[]
  recipeIngredients  RecipeIngredient[]
  auditLogs          AuditLog[]
  requisitionLines   RequisitionLine[]

  @@unique([sku, organizationId])
}

model InventoryRecord {
  id           String    @id @default(cuid())
  itemId       String
  locationId   String
  quantity     Float     @default(0)
  minStock     Float     @default(0)
  maxStock     Float     @default(100)
  reorderPoint Float     @default(10)
  expiryDate   DateTime?
  lastUpdated  DateTime  @default(now())

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([itemId, locationId])
}

model StockMovement {
  id          String   @id @default(cuid())
  itemId      String
  locationId  String
  type        String
  quantity    Float
  reference   String?
  notes       String?
  userId      String
  expiryDate  DateTime?
  batchNumber String?
  lotNumber   String?
  createdAt   DateTime @default(now())

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

model Supplier {
  id             String   @id @default(cuid())
  name           String
  contact        String?
  email          String?
  phone          String?
  address        String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id             String    @id @default(cuid())
  supplierId     String
  organizationId String
  status         String    @default("DRAFT")
  totalAmount    Float     @default(0)
  notes          String?
  orderDate      DateTime  @default(now())
  expectedDate   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier     Supplier           @relation(fields: [supplierId], references: [id])
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        PurchaseOrderLine[]
}

model PurchaseOrderLine {
  id              String @id @default(cuid())
  purchaseOrderId String
  itemId          String
  quantity        Float
  unitCost        Float
  receivedQty     Float  @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  itemId         String
  locationId     String
  type           String
  status         String   @default("OPEN")
  message        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])
  location     Location     @relation(fields: [locationId], references: [id])
}

model Recipe {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  category            String?
  servings            Float    @default(1)
  sellingPrice        Float    @default(0)
  targetCostPercent   Float    @default(30)
  organizationId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ingredients  RecipeIngredient[]
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  itemId   String
  quantity Float
  unit     String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item   @relation(fields: [itemId], references: [id])
}

model Requisition {
  id             String   @id @default(cuid())
  organizationId String
  requestedById  String
  reviewedById   String?
  locationId     String
  status         String   @default("PENDING")
  notes          String?
  reviewNote     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy   User               @relation("RequisitionRequester", fields: [requestedById], references: [id])
  reviewedBy    User?              @relation("RequisitionReviewer", fields: [reviewedById], references: [id])
  location      Location           @relation(fields: [locationId], references: [id])
  lines         RequisitionLine[]
}

model RequisitionLine {
  id            String  @id @default(cuid())
  requisitionId String
  itemId        String
  quantity      Float
  notes         String?

  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id])
}

model ShiftHandover {
  id             String   @id @default(cuid())
  organizationId String
  locationId     String
  userId         String
  notes          String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  itemId         String?
  action         String
  entity         String
  entityId       String
  changes        String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  item         Item?        @relation(fields: [itemId], references: [id])
}

model Comment {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  entityType     String
  entityId       String
  body           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
}
